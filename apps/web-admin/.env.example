# ---------------------------------------------------------------------------
# @squarely/web-admin — environment variables
# Copy to `.env.local` for local development. In production set these in
# Vercel: Project Settings → Environment Variables. Do NOT commit real values.
# ---------------------------------------------------------------------------

# Supabase project URL (public). Exposed to the browser.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase anonymous/public API key (public). Safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase project URL used by server-side code.
SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase service-role key — SERVER ONLY SECRET. Full admin access; bypasses
# Row Level Security. Never expose to the browser or prefix with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Resend API key for transactional email (e.g. announcement notifications).
# Optional — if unset, sendEmail() is a no-op and just logs in development.
RESEND_API_KEY=

# From address for outbound email. Defaults to "Squarely <noreply@squarely.com>".
EMAIL_FROM=Squarely <noreply@squarely.com>
