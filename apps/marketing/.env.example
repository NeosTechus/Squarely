# ---------------------------------------------------------------------------
# @squarely/marketing — environment variables
# Copy to `.env.local` for local development. In production set these in
# Vercel: Project Settings → Environment Variables.
# ---------------------------------------------------------------------------

# Public URL of the web-admin app. Marketing pages link/redirect here (e.g.
# "Sign in" / "Get started"). In production point at the admin domain.
NEXT_PUBLIC_APP_URL=https://app.squarely.com
